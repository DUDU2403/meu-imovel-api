# ============================================================
# CONFIGURAÇÃO DO SERVIDOR
# ============================================================

# URL de conexão com MongoDB
# Exemplo local: mongodb://localhost:27017/webstory
# Exemplo Atlas: mongodb+srv://usuario:senha@cluster.mongodb.net/webstory
MONGO_URI=mongodb://localhost:27017/webstory

# Segredo para assinar tokens JWT
JWT_SECRET=sua_chave_secreta_super_segura_aqui_12345

# Email do administrador
ADMIN_EMAIL=admin@webstory.com

# Porta do servidor (padrão: 10000)
PORT=10000

# ============================================================
# VARIÁVEIS OPCIONAIS (frontend)
# ============================================================

# VITE_API_URL=http://localhost:10000
# VITE_ADMIN_EMAIL=admin@webstory.com
